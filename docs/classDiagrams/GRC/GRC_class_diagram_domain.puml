@startuml DomainClassDiagram
skinparam classAttributeIconSize 0
skinparam linetype ortho

'==================================================
' FACHADA DEL MODULO (API)
'==================================================

interface IGestionInmueblesAPI{
+consultarPropiedades()
+consultarCatalogo()
+consultarReporteCambios()
+registrarCasoFortuito()
}

'==================================================
' FACTORY
'==================================================

interface InmuebleFactory{
+crearDepartamento():Departamento
+crearSuite():Suite
+crearSalonEventos():SalonDeEventos
+crearAreaRecreacional():AreaRecreacional
+crearParqueadero():Parqueadero
}

class InmuebleFactoryImpl

InmuebleFactory <|.. InmuebleFactoryImpl

'==================================================
' ITERATOR
'==================================================

interface IteratorInmueble{
+hasNext():boolean
+next():Inmueble
}

class CatalogoIterator

IteratorInmueble <|.. CatalogoIterator

'==================================================
' SINGLETON
'==================================================

class GestorPlazas <<Singleton>>{
-instance:GestorPlazas
+getInstance()
+asignarPlaza()
+liberarPlaza()
}

'==================================================
' CLASE ABSTRACTA PADRE
'==================================================

abstract class Inmueble{
-idInmueble:int
-codigo:String
-estado:EstadoInmueble
-areaMetrosCuadrados:double
-descripcion:String

+{abstract} registrar()
+actualizarEstado()
+{abstract} consultar()
}

enum EstadoInmueble{
DISPONIBLE
OCUPADO
EN_MANTENIMIENTO
EN_REMODELACION
VENDIDO
}

'==================================================
' HIJAS
'==================================================

class Departamento{
-numeroDepartamento:int
-piso:int
-numeroHabitaciones:int
-numeroBanos:int
-disponibleAlquiler:boolean
-disponibleVenta:boolean
}

class Suite{
-numeroHabitaciones:int
-numeroBanos:int
-tieneBalcon:boolean
-disponibleAlquiler:boolean
-disponibleVenta:boolean
}

abstract class EspacioComun{
#id:String
#nombre:String
#aforoMaximo:int

+estaDisponible()
}

class SalonDeEventos{
-costoReserva:Double
-requiereGarantia:boolean
}

class AreaRecreacional{
-tipoCancha:String
-requiereEquipamiento:boolean
}

class Parqueadero{
-idParqueadero:int
-nombre:String

+calcularPlazasDisponibles()
+consultarPlazas()
}

'==================================================
' PLAZAS
'==================================================

abstract class Plaza{
-numeroPlaza:String
-disponible:boolean

+{abstract} verificarPermiso()
+obtenerTiempoMaximo()
}

class PlazaPropietario{
+verificarPermiso()
}

class PlazaVisita{
-tiempoMaximo:int

+verificarPermiso()
}

'==================================================
' COMPONENTES
'==================================================

class CatalogoCondominio{
-idCatalogo:int
-fechaActualizacion:Date
-listaInmuebles:List<Inmueble>

+agregarInmueble()
+eliminarInmueble()
+actualizarCatalogo()
+consultarCatalogo()
+calcularCantidadPlazasVisita()

+createIterator():IteratorInmueble
}

class ReporteCambio{
-idReporte:int
-fechaGeneracion:Date
-descripcionCambio:String

+registrarCambio()
+consultarReporte()
}

class Propiedad{
-idPropiedad:int
-enAlquiler:boolean
-fechaRegistro:Date

+consultarPropiedad()
+actualizarPropietario()
+actualizarEstadoAlquiler()
}

class CasoFortuito{
-idCaso:int
-descripcion:String
-fecha:Date
-estado:EstadoCaso

+registrarCaso()
+actualizarCaso()
+cerrarCaso()
}

enum EstadoCaso{
REPORTADO
EN_PROCESO
RESUELTO
}

'==================================================
' HERENCIA
'==================================================

Inmueble <|-- Departamento
Inmueble <|-- Suite
Inmueble <|-- EspacioComun
Inmueble <|-- Parqueadero

EspacioComun <|-- SalonDeEventos
EspacioComun <|-- AreaRecreacional

Plaza <|-- PlazaPropietario
Plaza <|-- PlazaVisita

'==================================================
' COMPOSICION
'==================================================

Parqueadero "1" *-- "0..*" Plaza

'==================================================
' RELACIONES
'==================================================

CatalogoCondominio "1" o-- "*" Inmueble

Inmueble --> EstadoInmueble

CasoFortuito --> EstadoCaso

Inmueble "1" --> "*" ReporteCambio

Inmueble "1" --> "*" CasoFortuito

Propiedad "*" --> "1" Inmueble

PlazaPropietario "*" --> "1" Propiedad

'==================================================
' RELACIONES PATRONES
'==================================================

CatalogoCondominio --> IteratorInmueble : createIterator()

InmuebleFactoryImpl ..> Departamento : crea
InmuebleFactoryImpl ..> Suite : crea
InmuebleFactoryImpl ..> SalonDeEventos : crea
InmuebleFactoryImpl ..> AreaRecreacional : crea
InmuebleFactoryImpl ..> Parqueadero : crea

GestorPlazas --> Plaza
GestorPlazas --> Parqueadero

IGestionInmueblesAPI ..> CatalogoCondominio
IGestionInmueblesAPI ..> Propiedad
IGestionInmueblesAPI ..> ReporteCambio
IGestionInmueblesAPI ..> CasoFortuito

@enduml
